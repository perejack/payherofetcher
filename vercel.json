{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/payhero/initiate",
      "destination": "/api/payhero/initiate.js"
    },
    {
      "source": "/api/payhero/status",
      "destination": "/api/payhero/status.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
